<launch version="0.1.1">

  <arg name="localization" 
    default="false" 
    description="Whether to use SLAM Toolbox in mapping mode or AMCL for localization only" />
  
  <arg name="slam_params_file" 
    default="$(find-pkg-share raph_nav)/config/slam_toolbox.yaml"
    description="Path to the SLAM parameters file (used if localization is false)" />
  
  <arg name="amcl_params_file" 
    default="$(find-pkg-share raph_nav)/config/amcl.yaml"
    description="Path to the AMCL parameters file (used if localization is true)" />

  <arg name="map_file" 
    default="$(find-pkg-share raph_nav)/maps/empty_map.yaml"
    description="Path to the map file (required for AMCL - when localization is true)" />

  <arg name="navigation_params_file"
    default="$(find-pkg-share raph_nav)/config/navigation.yaml"
    description="Navigation parameters file for LiDAR and stereo camera setup" />

  <include unless="$(var localization)"
    file="$(find-pkg-share raph_nav)/launch/slam_toolbox.launch.py">
    <arg name="params_file" value="$(var slam_params_file)" />
  </include>

  <include if="$(var localization)"
    file="$(find-pkg-share raph_nav)/launch/amcl.launch.py">
    <arg name="params_file" value="$(var amcl_params_file)" />
    <arg name="map_file" value="$(var map_file)" />
  </include>

  <node_container namespace=""
    name="navigation_container"
    pkg="rclcpp_components"
    exec="component_container_isolated">
    <param from="$(var navigation_params_file)" />

    <composable_node name="nav2_point_cloud_xyz"
      pkg="depth_image_proc"
      plugin="depth_image_proc::PointCloudXyzNode">
      <extra_arg name="use_intra_process_comms" value="true" />
      <remap from="image_rect" to="oak/stereo/image_raw" />
      <remap from="camera_info" to="oak/stereo/camera_info" />
      <remap from="points" to="nav2/points" />

      <param name="queue_size" value="1" />
      <param name="qos_overrides./nav2/points.publisher.reliability" value="best_effort" />
      <param name="qos_overrides./nav2/points.publisher.history" value="keep_last" />
      <param name="qos_overrides./nav2/points.publisher.depth" value="1" />
    </composable_node>

    <composable_node name="planner_server"
      pkg="nav2_planner"
      plugin="nav2_planner::PlannerServer">
      <extra_arg name="use_intra_process_comms" value="true" />
      <param from="$(var navigation_params_file)" />
    </composable_node>

    <composable_node name="controller_server"
      pkg="nav2_controller"
      plugin="nav2_controller::ControllerServer">
      <extra_arg name="use_intra_process_comms" value="true" />
      <param from="$(var navigation_params_file)" />
      <remap from="cmd_vel" to="dummy/cmd_vel" />
    </composable_node>

    <composable_node name="behavior_server"
      pkg="nav2_behaviors"
      plugin="behavior_server::BehaviorServer">
      <extra_arg name="use_intra_process_comms" value="true" />
      <param from="$(var navigation_params_file)" />
    </composable_node>

    <composable_node name="bt_navigator"
      pkg="nav2_bt_navigator"
      plugin="nav2_bt_navigator::BtNavigator">
      <param name="default_nav_to_pose_bt_xml"
        value="$(find-pkg-share raph_nav)/config/behavior_trees/navigate_to_pose_w_replanning.xml" />
      <param name="default_nav_through_poses_bt_xml"
        value="$(find-pkg-share raph_nav)/config/behavior_trees/navigate_through_poses_w_replanning.xml" />
      <param from="$(var navigation_params_file)" />
    </composable_node>

    <composable_node name="waypoint_follower"
      pkg="nav2_waypoint_follower"
      plugin="nav2_waypoint_follower::WaypointFollower">
      <param from="$(var navigation_params_file)" />
    </composable_node>

    <composable_node name="lifecycle_manager_navigation"
      pkg="nav2_lifecycle_manager"
      plugin="nav2_lifecycle_manager::LifecycleManager">
      <extra_arg name="use_intra_process_comms" value="true" />
      <param from="$(var navigation_params_file)" />
    </composable_node>
  </node_container>
</launch>
